# Runtime database location. If unset, the app uses ./heatstroke_records.db.
HEATSTROKE_DB_PATH=./runtime/heatstroke_records.db

# Optional app mode label for deployment docs or future feature flags.
APP_ENV=demo

# Optional: set this to 1 in hosted demos where you want demo data seeded manually
# from the sidebar admin/demo tools.
ENABLE_DEMO_DATA=1

# Weather lookup currently uses wttr.in and does not need an API key.
# WEATHER_API_KEY=
